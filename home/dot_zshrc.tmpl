# ========== zsh options ==========
setopt auto_pushd
setopt pushd_ignore_dups
setopt hist_ignore_dups
setopt share_history
setopt inc_append_history
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=100000
export SAVEHIST=100000

# ========== PATH ==========
export PATH="$HOME/.local/bin:$PATH"

# pnpm
{{ if eq .chezmoi.os "darwin" -}}
export PNPM_HOME="{{ .chezmoi.homeDir }}/Library/pnpm"
{{ else -}}
export PNPM_HOME="{{ .chezmoi.homeDir }}/.local/share/pnpm"
{{ end -}}
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# ========== tools (sync load) ==========
if command -v mise &>/dev/null; then eval "$(mise activate zsh)"; fi
if command -v direnv &>/dev/null; then eval "$(direnv hook zsh)"; fi
if command -v starship &>/dev/null; then eval "$(starship init zsh)"; fi
if command -v zoxide &>/dev/null; then eval "$(zoxide init zsh)"; fi

# ========== dmux shim PATH (tmux only) ==========
# Inside tmux (incl. dmux agent panes) keep the dmux shim dir ahead of the mise-managed real
# binaries so the claude/codex shims in ~/.config/dmux/bin actually intercept. `mise activate`
# above re-prepends the real binaries, dropping the dir the dmux wrappers put on the server env;
# re-adding it here (after mise) is what makes the shims work inside panes — without it dmux runs
# the real claude/codex directly (no happy wrapping, no `--profile shared`). Skipped outside tmux
# so non-tmux shells keep the documented bare-binary behaviour.
if [[ -n "$TMUX" && -d "$HOME/.config/dmux/bin" ]]; then
  export PATH="$HOME/.config/dmux/bin:$PATH"
fi

# ========== sheldon (deferred plugins) ==========
if command -v sheldon &>/dev/null; then eval "$(sheldon source)"; fi

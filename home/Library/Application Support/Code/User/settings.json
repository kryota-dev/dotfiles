{
  "chat.editor.fontSize": 12,
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.cpp.disabledLanguages": ["plaintext", "scminput"],
  "database-client.autoSync": true,
  "editor.accessibilitySupport": "off",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.detectIndentation": false,
  "editor.fontFamily": "Moralerspace Neon, "Ricty Diminished", Menlo, MesloLGS NF, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.inlineSuggest.enabled": true,
  "editor.minimap.enabled": false,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.renderWhitespace": "all",
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
  },
  "emmet.variables": {
    "lang": "ja",
  },
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "figma.autocompleteBlocks": true,
  "files.autoSave": "afterDelay",
  "files.exclude": {
    "!**/.git": true,
    "**/*Zone.Identifier": true,
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.git": false,
    "**/.project": true,
    "**/.settings": true,
  },
  "files.insertFinalNewline": true,
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "never",
  "githubPullRequests.pullBranch": "never",
  "gitmoji.outputType": "code",
  "gitmoji.showEmojiCode": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "latex-workshop.latex.recipes": [
    {
      "name": "toolchain",
      "tools": ["Step 1: ptex2pdf", "Step 2: pbibtex", "Step 3: ptex2pdf", "Step 4: ptex2pdf"],
    },
  ],
  "latex-workshop.latex.tools": [
    {
      "args": ["-l", "-ot", "-kanji=utf8 -synctex=1", "%DOC%"],
      "command": "ptex2pdf",
      "name": "Step 1: ptex2pdf",
    },
    {
      "args": ["%DOCFILE%", "-kanji=utf8"],
      "command": "pbibtex",
      "name": "Step 2: pbibtex",
    },
    {
      "args": ["-l", "-ot", "-kanji=utf8 -synctex=1", "%DOC%"],
      "command": "ptex2pdf",
      "name": "Step 3: ptex2pdf",
    },
    {
      "args": ["-l", "-ot", "-kanji=utf8 -synctex=1", "%DOC%"],
      "command": "ptex2pdf",
      "name": "Step 4: ptex2pdf",
    },
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "liveServer.settings.donotShowInfoMsg": true,
  "makefile.configureOnOpen": true,
  "markdown-pdf.displayHeaderFooter": false,
  "markdown-pdf.format": "A3",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left",
  },
  "prettier.arrowParens": "always",
  "prettier.bracketSpacing": true,
  "prettier.embeddedLanguageFormatting": "auto",
  "prettier.endOfLine": "lf",
  "prettier.htmlWhitespaceSensitivity": "css",
  "prettier.jsxSingleQuote": true,
  "prettier.printWidth": 120,
  "prettier.proseWrap": "preserve",
  "prettier.quoteProps": "as-needed",
  "prettier.singleQuote": true,
  "prettier.tabWidth": 2,
  "prettier.trailingComma": "all",
  "prettier.useTabs": false,
  "python.pythonPath": "/usr/local/bin/python3",
  "redhat.telemetry.enabled": true,
  "remote.SSH.remotePlatform": {
    "ryota-rp4.local": "linux",
    "ubuntu-dev": "linux",
  },
  "security.workspace.trust.untrustedFiles": "open",
  "tailwindCSS.experimental.classRegex": [
    "tv\\(([^)(]*(?:\\([^)(]*(?:\\([^)(]*(?:\\([^)(]*\\)[^)(]*)*\\)[^)(]*)*\\)[^)(]*)*)\\)",
  ],
  "terminal.external.osxExec": "Ghostty.app",
  "terminal.integrated.env.osx": {
    "CW_NEW_SESSION": "1",
    "FIG_NEW_SESSION": "1",
    "Q_NEW_SESSION": "1",
  },
  "terminal.integrated.fontFamily": "Moralerspace Neon",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.sendKeybindingsToShell": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "window.restoreWindows": "none",
  "workbench.activityBar.orientation": "vertical",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
  },
  "workbench.iconTheme": "material-icon-theme",
  "console-ninja.featureSet": "Community",
  "cursor.composer.shouldAllowCustomModes": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "workbench.colorTheme": "GitHub Dark",
  "cursor.windowSwitcher.sidebarHoverCollapsed": true,
  "material-icon-theme.activeIconPack": "react",
  "security.promptForLocalFileProtocolHandling": false,
  "vscord.app.name": "Cursor",
  "vscord.app.privacyMode.enable": true,
  "workbench.editor.wrapTabs": true,
  "swaggerViewer.previewInBrowser": true,
  "roo-cline.allowedCommands": ["git log", "git diff", "git show"],
  "roo-cline.deniedCommands": [],
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "files.insertFinalNewline": true,
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "github.copilot.nextEditSuggestions.enabled": true,
  "claudeCode.initialPermissionMode": "bypassPermissions",
  "claudeCode.allowDangerouslySkipPermissions": true,
  "claudeCode.preferredLocation": "panel",
  "claudeCode.selectedModel": "claude-opus-4-5-20251101",
  "git.replaceTagsWhenPull": true,
  "workbench.activityBar.location": "top",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
    "*.tfvars": false,
    "dotenv": false,
  },
  "terminal.integrated.accessibleViewPreserveCursorPosition": true,
  "docker.extension.enableComposeLanguageServer": false,
  "files.readonlyInclude": {
    "**/*.log": true,
    "**/*.csv": true,
    "**/*.xlsx": true,
    "**/*.pdf": true,
    "**/*.docx": true,
    "**/*.doc": true,
    "**/*.pptx": true,
  },
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true,
  },
  "search.useParentIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "hediet.vscode-drawio.resizeImages": null,
  "chat.viewSessions.orientation": "stacked",
}

#!/bin/bash
# mise config hash: {{ include "dot_config/mise/config.toml" | sha256sum }}
set -euo pipefail

if ! command -v mise &>/dev/null; then
  echo "WARNING: mise is not installed. Skipping tool installation."
  echo "Install it with: brew install mise"
  exit 0
fi

echo "==> Installing mise-managed tools..."

# Set GITHUB_TOKEN from gh CLI to avoid GitHub API rate limiting.
# On initial setup, gh may not yet be installed (it's managed by mise),
# so this is a best-effort approach — if gh is unavailable, mise install
# proceeds without authentication and may hit rate limits.
if [[ -z "${GITHUB_TOKEN:-}" ]]; then
  if command -v gh &>/dev/null && gh auth status &>/dev/null 2>&1; then
    GITHUB_TOKEN=$(gh auth token)
    export GITHUB_TOKEN
    echo "GITHUB_TOKEN set from gh CLI."
  fi
fi

for attempt in 1 2 3; do
  if mise install --yes; then
    echo "==> mise tools installed successfully."
    break
  elif [[ $attempt -lt 3 ]]; then
    echo "WARNING: mise install failed (attempt ${attempt}/3), retrying in $((attempt * 10)) seconds..."
    sleep $((attempt * 10))
  else
    echo "ERROR: mise install failed after 3 attempts."
    exit 1
  fi
done

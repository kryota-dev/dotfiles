[user]
	name = kryota-dev
	email = {{ .email }}
	signingkey = {{ .signingkey }}
[core]
	excludesfile = ~/.gitignore_global
	editor = nvim
	ignorecase = false
[commit]
	gpgsign = true
[gpg]
	format = ssh
[init]
	defaultBranch = main
{{- $opSign := "" }}
{{- if stat "/Applications/1Password.app/Contents/MacOS/op-ssh-sign" }}
{{-   $opSign = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign" }}
{{- else if stat "/opt/1Password/op-ssh-sign" }}
{{-   $opSign = "/opt/1Password/op-ssh-sign" }}
{{- end }}
{{- if $opSign }}
[gpg "ssh"]
	program = {{ $opSign }}
{{- end }}
[extensions]
	worktreeConfig = true

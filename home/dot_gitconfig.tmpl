[user]
	name = {{ .name }}
	email = {{ .email }}
	signingkey = {{ .signingkey }}
[core]
	excludesfile = ~/.gitignore_global
	editor = nvim
	ignorecase = false
	# Global hooks dir (task #31): runs the gitleaks secret-scan pre-commit on
	# every commit across harnesses. A repo with its own core.hooksPath (e.g.
	# husky) overrides this locally; CI gitleaks is the backstop there.
	hooksPath = ~/.config/git/hooks
[commit]
	gpgsign = true
[gpg]
	format = ssh
[init]
	defaultBranch = main
{{- $opSign := "" }}
{{- if stat "/Applications/1Password.app/Contents/MacOS/op-ssh-sign" }}
{{-   $opSign = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign" }}
{{- else if stat "/opt/1Password/op-ssh-sign" }}
{{-   $opSign = "/opt/1Password/op-ssh-sign" }}
{{- end }}
{{- if $opSign }}
[gpg "ssh"]
	program = "{{ $opSign }}"
{{- end }}
[extensions]
	worktreeConfig = true
[ghq]
	root = ~/ghq
	user = {{ .ghq_user }}

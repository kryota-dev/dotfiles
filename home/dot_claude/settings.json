{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "95",
    "MAX_THINKING_TOKENS": "31999",
    "CLAUDE_CODE_DISABLE_MOUSE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(pwd)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",

      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",

      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(npx:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git tag:*)",
      "Bash(git show:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git remote -v)",

      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(docker compose:*)",

      "Bash(tsc:*)",
      "Bash(tsx:*)",

      "Bash(jest:*)",
      "Bash(vitest:*)",
      "Bash(playwright:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(biome:*)",

      "Bash(osascript -e 'display notification*)",

      "Bash(gh search:*)",

      "mcp__claude_ai_Google_Calendar__list_events",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",

      "Read(**/.env*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",

      "Write(**/.env*)",
      "Write(**/secrets/**)",

      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(curl:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",

      "Bash(env:*)",
      "Bash(printenv:*)",

      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",

      "Bash(*.gmail-mcp*)",
      "Bash(*.gmail-mcp/credentials.json*)",
      "Bash(*.gmail-mcp/gcp-oauth.keys.json*)",
      "mcp__supabase__execute_sql"
    ],
    "defaultMode": "auto"
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 20
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "95",
    "MAX_THINKING_TOKENS": "127999",
    "ECC_GOVERNANCE_CAPTURE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(pwd)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",

      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",

      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(npx:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git tag:*)",
      "Bash(git show:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git remote -v)",

      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(docker compose:*)",

      "Bash(tsc:*)",
      "Bash(tsx:*)",

      "Bash(jest:*)",
      "Bash(vitest:*)",
      "Bash(playwright:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(biome:*)",

      "Bash(osascript -e 'display notification*)",

      "Bash(gh search:*)",

      "mcp__claude_ai_Google_Calendar__list_events",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git reset:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",

      "Read(**/.env*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",

      "Write(**/.env*)",
      "Write(**/secrets/**)",

      "Bash(env:*)",
      "Bash(printenv:*)",

      "Bash(*.gmail-mcp*)",
      "Bash(*.gmail-mcp/credentials.json*)",
      "Bash(*.gmail-mcp/gcp-oauth.keys.json*)",
      "mcp__supabase__execute_sql"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/session-start-bootstrap.js"
          }
        ],
        "description": "Load previous context and detect package manager on new session",
        "id": "session:start"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js pre:compact scripts/hooks/pre-compact.js standard,strict"
          }
        ],
        "description": "Save state before context compaction",
        "id": "pre:compact"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js pre:edit-write:suggest-compact scripts/hooks/suggest-compact.js standard,strict"
          }
        ],
        "description": "Suggest manual compaction at logical intervals",
        "id": "pre:edit-write:suggest-compact"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js pre:config-protection scripts/hooks/config-protection.js standard,strict",
            "timeout": 5
          }
        ],
        "description": "Block edits to linter/formatter config files (bypass with ECC_DISABLED_HOOKS=pre:config-protection)",
        "id": "pre:config-protection"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js pre:edit-write:gateguard-fact-force scripts/hooks/gateguard-fact-force.js standard,strict",
            "timeout": 5
          }
        ],
        "description": "Fact-forcing gate: require articulating impact before the first Edit/Write per file",
        "id": "pre:edit-write:gateguard-fact-force"
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks-fork/governance-capture.js\"",
            "timeout": 10
          }
        ],
        "description": "Capture governance events (secrets, approval-required commands, sensitive paths) to per-account state.db. Forked from ECC to add persistence; enable with ECC_GOVERNANCE_CAPTURE=1",
        "id": "pre:governance-capture"
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js pre:mcp-health-check scripts/hooks/mcp-health-check.js standard,strict"
          }
        ],
        "description": "Probe MCP server health before MCP tool execution (matcher narrowed to mcp__.* per task #13 so non-MCP tools never pay the hook cost)",
        "id": "pre:mcp-health-check"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js pre:write:doc-file-warning scripts/hooks/doc-file-warning.js standard,strict"
          }
        ],
        "description": "Warn when creating non-standard scratch documentation files (TODO.md/NOTES.md/etc.) outside structured directories",
        "id": "pre:write:doc-file-warning"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js post:ecc-metrics-bridge scripts/hooks/ecc-metrics-bridge.js minimal,standard,strict",
            "timeout": 10
          }
        ],
        "description": "Maintain running session metrics aggregate for statusline and context monitor",
        "id": "post:ecc-metrics-bridge"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js post:ecc-context-monitor scripts/hooks/ecc-context-monitor.js standard,strict",
            "timeout": 10
          }
        ],
        "description": "Inject agent warnings on context exhaustion, high cost, scope creep, or tool loops",
        "id": "post:ecc-context-monitor"
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks-fork/governance-capture.js\"",
            "timeout": 10
          }
        ],
        "description": "Capture governance events from tool outputs to per-account state.db (pairs with pre:governance-capture)",
        "id": "post:governance-capture"
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js post:mcp-health-check scripts/hooks/mcp-health-check.js standard,strict"
          }
        ],
        "description": "Track failed MCP tool calls, mark unhealthy servers, and attempt reconnect",
        "id": "post:mcp-health-check"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js stop:session-end scripts/hooks/session-end.js minimal,standard,strict",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Persist session state after each response (Stop carries transcript_path)",
        "id": "stop:session-end"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js stop:cost-tracker scripts/hooks/cost-tracker.js minimal,standard,strict",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Track token and cost metrics per session",
        "id": "stop:cost-tracker"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/ecc-hook.sh scripts/hooks/run-with-flags.js stop:desktop-notify scripts/hooks/desktop-notify.js standard,strict",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Send desktop notification (macOS/WSL) with task summary when Claude responds",
        "id": "stop:desktop-notify"
      }
    ]
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": false,
  "cleanupPeriodDays": 20,
  "statusLine": {
    "type": "command",
    "command": "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/statusline.sh"
  },
  "model": "claude-opus-4-8[1m]",
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {},
  "agentPushNotifEnabled": true
}

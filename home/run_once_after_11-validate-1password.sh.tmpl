#!/bin/bash
{{ if ne .chezmoi.os "darwin" -}}
echo "Skipping: not macOS"
exit 0
{{ end -}}

set -euo pipefail

echo "==> Validating 1Password CLI setup..."

if ! command -v op &>/dev/null; then
  echo "ERROR: 1Password CLI (op) is not installed."
  echo "Install it with: brew install --cask 1password-cli"
  exit 1
fi

echo "==> 1Password CLI found. Checking authentication..."

if ! op account list &>/dev/null; then
  echo "ERROR: 1Password CLI is not authenticated."
  echo "Please sign in to 1Password desktop app and enable CLI integration:"
  echo "  1Password > Settings > Developer > Integrate with 1Password CLI"
  exit 1
fi

echo "==> Verifying required 1Password items exist..."

ITEMS=(
  "op://kryota.dev/Dotfiles - AWS Config/notesPlain"
  # API keys for the exa / firecrawl user-scope MCP servers (rendered into the 0600
  # ~/.config/zsh/claude-secrets.zsh). Create these as items exposing a `credential` field.
  "op://kryota.dev/Dotfiles - Exa API/credential"
  "op://kryota.dev/Dotfiles - Firecrawl API/credential"
  # Client/employer identifier pattern for the gitleaks client-identifiers rule
  # (rendered into the 0600 ~/.config/git/gitleaks-own.toml, used by the global
  # pre-commit hook for own-namespace repos only). Create as a Secure Note
  # exposing a `pattern` field holding a single `name1|name2|...` alternation.
  "op://kryota.dev/Dotfiles - Redact Patterns/pattern"
)

for item in "${ITEMS[@]}"; do
  if ! op read "$item" &>/dev/null; then
    echo "ERROR: Required 1Password item not found: $item"
    echo "Please create the missing Secure Note in the kryota.dev vault."
    exit 1
  fi
done

# Smoke-test the redact pattern beyond mere existence: an empty value renders
# the gitleaks rule as `(?i)()` (matches everything), and an invalid regex or
# an embedded `'''` breaks the whole rendered config, which would block every
# commit in own-namespace repos with a misleading error. Fail loudly here
# instead, where the cause is obvious.
pattern="$(op read "op://kryota.dev/Dotfiles - Redact Patterns/pattern" 2>/dev/null || true)"
if [ -z "$pattern" ]; then
  echo "ERROR: 'Dotfiles - Redact Patterns' exists but its 'pattern' field is empty."
  exit 1
fi
case "$pattern" in
  *"'''"*)
    echo "ERROR: redact pattern contains ''' which breaks the TOML raw string in gitleaks-own.toml."
    exit 1
    ;;
esac
if command -v python3 &>/dev/null; then
  if ! printf '%s' "$pattern" | python3 -c 'import re, sys; re.compile("(?i)(%s)" % sys.stdin.read())' 2>/dev/null; then
    echo "ERROR: redact pattern does not compile as a regex (check unbalanced parens/brackets or stray metacharacters)."
    exit 1
  fi
fi

echo "==> All 1Password items verified successfully."

#!/usr/bin/env bash
# Global secret-scan pre-commit hook (task #31), wired via core.hooksPath so
# every commit — Claude, Codex, or human — is scanned for staged secrets with
# gitleaks. This is a git-layer (harness-agnostic) guardrail.
#
# core.hooksPath replaces the repo's .git/hooks dir for ALL hook types, so this
# hook also chains the repo's own .git/hooks/pre-commit when present (a repo
# that sets its own core.hooksPath, e.g. husky, never reaches this hook).
# Other raw .git/hooks types (commit-msg, …) are not chained here; repos that
# rely on those should use a hook manager that sets core.hooksPath.
#
# Caveats:
#   - `git commit --no-verify` bypasses it by design (per-harness policy).
#   - If gitleaks is not installed the scan is skipped (fail-open) so commits
#     are never bricked on a machine before `mise install` runs.
set -euo pipefail

# Resolve gitleaks: prefer a PATH binary (mise shims), else `mise exec`.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks_cmd=(gitleaks)
elif command -v mise >/dev/null 2>&1 && mise which gitleaks >/dev/null 2>&1; then
  gitleaks_cmd=(mise exec -- gitleaks)
else
  echo "[pre-commit] gitleaks not found; skipping secret scan (CI/server-side scan is the backstop)." >&2
  gitleaks_cmd=()
fi

if [ "${#gitleaks_cmd[@]}" -gt 0 ]; then
  # Prefer a repo-local gitleaks config (so per-repo rules/allowlists win);
  # fall back to a global config only when the repo defines none. Passing
  # --config unconditionally would shadow the repo's own .gitleaks.toml.
  #
  # Global config selection is OWNER-SCOPED: repos whose origin remote is
  # under the user's own GitHub namespaces (or repos with no remote yet —
  # they may be pushed public later, so fail safe) get the stricter
  # gitleaks-own.toml, which adds the 1Password-rendered client-identifier
  # rule. Client/work repos legitimately contain their own identifiers, so
  # they get the base gitleaks.toml (default ruleset + allowlist only).
  toplevel="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  scan_args=(git --staged --redact --no-banner)
  if [ -n "$toplevel" ] && [ -f "${toplevel}/.gitleaks.toml" ]; then
    : # gitleaks auto-discovers the repo-local config; do not override it.
  else
    origin_url="$(git remote get-url origin 2>/dev/null || true)"
    global_config="${HOME}/.config/git/gitleaks.toml"
    case "$origin_url" in
      "" | *github.com[:/]kryota-dev/* | *github.com[:/]ryota-k0827/*)
        # Fall back to the base config if the strict one has not been
        # rendered yet (fresh machine before the 1Password item exists).
        if [ -f "${HOME}/.config/git/gitleaks-own.toml" ]; then
          global_config="${HOME}/.config/git/gitleaks-own.toml"
        fi
        ;;
    esac
    if [ -f "$global_config" ]; then
      scan_args+=(--config "$global_config")
    fi
  fi

  if ! "${gitleaks_cmd[@]}" "${scan_args[@]}"; then
    cat >&2 <<'MSG'
[pre-commit] gitleaks detected a potential secret in the staged changes.
The commit was aborted. Secret values are redacted above; to inspect the full
match for a false-positive review, re-run the command shown in the scan output
(own-namespace repos use ~/.config/git/gitleaks-own.toml, other repos use
~/.config/git/gitleaks.toml). If it is a false positive, add an allowlist
entry to the config that was used.
NOTE: a config parse/regex error also lands here — check the gitleaks output
above; if it mentions a config failure, fix the config instead.
To override (NOT recommended): git commit --no-verify
MSG
    exit 1
  fi
fi

# Chain the repo's own pre-commit hook, which core.hooksPath would otherwise
# replace. IMPORTANT: `git rev-parse --git-path hooks/pre-commit` RESPECTS
# core.hooksPath (git 2.x), so it resolves back to THIS global hook and would
# infinite-loop via exec. Resolve the default hooks dir from --git-common-dir
# instead: it ignores core.hooksPath (no loop) AND points at the shared .git, so
# linked worktrees — whose per-worktree --git-dir has no hooks/ — still chain.
# --path-format=absolute avoids a relative-path ambiguity. Skip if it points
# back at this script (self-reference guard via -ef, covers symlink deploys too).
common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
if [ -n "$common_dir" ]; then
  local_hook="${common_dir}/hooks/pre-commit"
  if [ -x "$local_hook" ] && ! [ "$local_hook" -ef "${BASH_SOURCE[0]}" ]; then
    exec "$local_hook" "$@"
  fi
fi

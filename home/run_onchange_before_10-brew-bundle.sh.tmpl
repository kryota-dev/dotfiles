#!/bin/bash
set -euo pipefail

# Brewfile hash: {{ include "dot_Brewfile" | sha256sum }}
{{ if eq .chezmoi.os "linux" -}}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
echo "Running brew bundle (Linux: filtering incompatible formulas)..."
BREWFILE="{{ .chezmoi.sourceDir }}/dot_Brewfile"
EXCLUDE="{{ .chezmoi.sourceDir }}/../.brewfile-linux-exclude"
grep -v -E -f "$EXCLUDE" "$BREWFILE" >/tmp/Brewfile.linux
brew bundle --no-upgrade --file=/tmp/Brewfile.linux
rm -f /tmp/Brewfile.linux
{{ else -}}
echo "Running brew bundle..."
brew bundle --no-upgrade --file="{{ .chezmoi.sourceDir }}/dot_Brewfile"
{{ end -}}
echo "Brew bundle complete."

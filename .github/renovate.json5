{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinAllExceptPeerDependencies",
    "mergeConfidence:all-badges",
    ":disableRateLimiting",
    ":prConcurrentLimit10",
    "group:definitelyTyped",
    "helpers:pinGitHubActionDigests"
  ],
  "rebaseWhen": "conflicted",
  "automergeType": "pr",
  "minor": {
    "automerge": false
  },
  "patch": {
    "automerge": true
  },
  "pin": {
    "automerge": true
  },
  "ignoreTests": false,
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/ci\\.yml$"],
      "matchStrings": [
        "SHFMT_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "mvdan/sh",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["home/\\.chezmoiexternal\\.toml$"],
      "matchStrings": [
        "url\\s*=\\s*\"https://github\\.com/(?<depName>[^/]+/[^/]+)/archive/(?<currentDigest>[a-f0-9]+)\\.tar\\.gz\""
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{{depName}}}",
      "currentValueTemplate": "main"
    }
  ],
  "mise": {
    "fileMatch": [
      "home/dot_config/mise/config\\.toml"
    ]
  }
}
